{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Compilar e Rodar Raylib",
            "command": "cd ${workspaceFolder}\\Projeto && g++ main.cpp Estruturas/estruturas.cpp Mapa/mapa.cpp Personagem/personagem.cpp Game/game.cpp Menu/menu.cpp -o programa.exe -I raylib/include -L raylib/lib -lraylib -lopengl32 -lgdi32 -lwinmm && programa.exe",
            "args": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": ["$gcc"],
            "options": {
                "shell": {
                    "executable": "cmd.exe",
                    "args": ["/C"]
                }
            }
        }
    ]
}