{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar HollowKnight",
            "type": "shell",
            "command": "g++",
            "args": [
                "-g",
                "Projeto/main.cpp",
                "Projeto/Funcoes/funcoes.cpp",
                "Projeto/Estruturas/estruturas.cpp",
                "-o",
                "jogo",
                "-lraylib",
                "-lGL",
                "-lm",
                "-lpthread",
                "-ldl",
                "-lrt",
                "-lX11"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}